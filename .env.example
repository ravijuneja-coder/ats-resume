# Copy this file to .env and fill in your keys

# Anthropic API key — enables AI writing features.
# NOT prefixed with VITE_: this is read server-side only, by api/claude.js
# (a Vercel serverless function). Never rename this to VITE_ANTHROPIC_API_KEY —
# that would ship the key inside the client bundle where anyone could steal it.
ANTHROPIC_API_KEY=sk-ant-...

# SMTP credentials — sends the Contact page form as an email, via the
# support@atsresumepilot.com mailbox hosted on Hostinger, to
# support@atsresumepilot.com. NOT prefixed with VITE_: read server-side
# only, by api/contact.js.
# Hostinger SMTP: host smtp.hostinger.com, port 465 (SSL, recommended) or
# 587 (STARTTLS). SMTP_PASS is the mailbox's regular password, set in
# Hostinger → Emails → Email Accounts — no app password needed.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=support@atsresumepilot.com
SMTP_PASS=...
# Optional — defaults to support@atsresumepilot.com if unset.
CONTACT_TO_EMAIL=support@atsresumepilot.com

# Firebase — client config from Firebase Console → Project Settings → Your apps.
# Safe to expose in the client bundle; access control is enforced by
# Firestore security rules (see firestore.rules), not by hiding these values.
# "Continue with Google" goes through Firebase's Google provider (enabled in
# Firebase Console → Authentication → Sign-in method), so no separate
# Google OAuth client ID is needed here.
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
