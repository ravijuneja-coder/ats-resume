# Copy this file to .env and fill in your keys

# Anthropic API key — enables AI writing features
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth Client ID — enables "Continue with Google"
VITE_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Stripe Payment Link — enables real payments for Premium plan
# 1. Go to dashboard.stripe.com
# 2. Products → Add Product → "Premium Plan" · $9/month · Recurring
# 3. Payment Links → + New → select the product
# 4. After payment → Success URL: http://localhost:5173?payment=success
# 5. Copy the payment link URL below
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your-link-here
