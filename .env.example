# Copy this file to .env and fill in your keys

# Anthropic API key — enables AI writing features.
# NOT prefixed with VITE_: this is read server-side only, by api/claude.js
# (a Vercel serverless function). Never rename this to VITE_ANTHROPIC_API_KEY —
# that would ship the key inside the client bundle where anyone could steal it.
ANTHROPIC_API_KEY=sk-ant-...

# Firebase — client config from Firebase Console → Project Settings → Your apps.
# Safe to expose in the client bundle; access control is enforced by
# Firestore security rules (see firestore.rules), not by hiding these values.
# "Continue with Google" goes through Firebase's Google provider (enabled in
# Firebase Console → Authentication → Sign-in method), so no separate
# Google OAuth client ID is needed here.
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
